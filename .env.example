# .env.example - Gemini AI yapılandırması örneği

# Database Configuration
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/emlakai
REDIS_URL=redis://localhost:6379/0

# Gemini AI Configuration (https://aistudio.google.com adresinden key alın)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
LLM_TIMEOUT_SECONDS=60

# Provider Configuration
SAHIBINDEN_SEARCH_URL=https://www.sahibinden.com/satilik-daire
EMLAKJET_SEARCH_URL=https://www.emlakjet.com/satilik-konut/
PROVIDER_REQUEST_TIMEOUT_SECONDS=20
PROVIDER_MAX_ITEMS=20

# OpenStreetMap APIs
OVERPASS_URL=https://overpass-api.de/api/interpreter
NOMINATIM_URL=https://nominatim.openstreetmap.org
USER_AGENT=EmlakAI/1.0

# Application Configuration
APP_NAME=EmlakAI Backend
APP_VERSION=0.1.0
ENVIRONMENT=development
SEED_ON_STARTUP=false
LOG_LEVEL=INFO

# CORS Configuration
CORS_ALLOWED_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
CORS_ALLOWED_CREDENTIALS=true
CORS_ALLOWED_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
CORS_ALLOWED_HEADERS=["*"]
